{
  "manifest_version": 3,
  "name": "WebFlag",
  "version": "1.0.0",
  "description": "Capture web bugs in one click: screenshot, annotate, grab the element selector + environment, and send straight to ClickUp.",
  "permissions": ["storage", "contextMenus", "unlimitedStorage"],
  "host_permissions": ["https://api.clickup.com/*", "<all_urls>"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "commands": {
    "pick-element": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Pick an element to report a bug"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
